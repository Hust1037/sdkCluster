{
 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# SDK聚类算法对比实验\n",
    "\n",
    "本notebook用于对比不同聚类算法在SDK样本上的性能表现。\n",
    "\n",
    "## 实验目的\n",
    "- 对比DBSCAN、K-Means、层次聚类和HDBSCAN四种算法的性能\n",
    "- 评估不同算法的聚类效果\n",
    "- 选择最适合SDK聚类的算法\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import json\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "from pathlib import Path\n",
    "from src.clustering_engine import SDKClusteringEngine\n",
    "\n",
    "# 设置中文字体\n",
    "plt.rcParams['font.sans-serif'] = ['SimHei']  # 用来正常显示中文标签\n",
    "plt.rcParams['axes.unicode_minus'] = False  # 用来正常显示负号\n",
    "\n",
    "# 设置样式\n",
    "sns.set_style(\"whitegrid\")\n",
    "sns.set_palette(\"husl\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. 加载数据\n",
    "首先加载处理好的特征数据。"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 加载特征数据\n",
    "feature_path = '../data/processed/processed_features.json'\n",
    "output_dir = '../data/processed'\n",
    "report_dir = '../reports'\n",
    "\n",
    "# 确保输出目录存在\n",
    "Path(output_dir).mkdir(parents=True, exist_ok=True)\n",
    "Path(report_dir).mkdir(parents=True, exist_ok=True)\n",
    "\n",
    "# 初始化聚类引擎\n",
    "engine = SDKClusteringEngine()\n",
    "\n",
    "# 加载特征数据\n",
    "try:\n",
    "    engine.load_features(feature_path)\n",
    "    print(f"\n特征数据加载成功，形状: {engine.feature_matrix.shape}")\n",
    "    print(f"样本数量: {len(engine.sample_info)}")\n",
    "except Exception as e:\n",
    "    print(f"加载特征数据失败: {e}")\n",
    "    print(f"请先运行特征工程: python src/feature_engineer.py")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. 算法对比\n",
    "对比四种聚类算法的性能表现。"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 运行算法对比\n",
    "try:\n",
    "    print(\"\n" + "="*60)\n",
    "    print(\"算法对比实验")\n",
    "    print(\"="*60)\n",
    "    \n",
    "    # 运行所有算法并比较\n",
    "    comparison_results = engine.compare_algorithms()\n",
    "    \n",
    "    # 打印对比结果\n",
    "    engine.print_comparison(comparison_results)\n",
    "    \n",
    "    # 保存对比结果\n",
    "    with open(f'{output_dir}/algorithm_comparison.json', 'w', encoding='utf-8') as f:\n",
    "        json.dump(comparison_results, f, ensure_ascii=False, indent=2)\n",
    "    \n",
    "    print(f"\n对比结果已保存到: {output_dir}/algorithm_comparison.json")\n",
    "except Exception as e:\n",
    "    print(f"算法对比失败: {e}")\n",
    "    import traceback\n",
    "    traceback.print_exc()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. 可视化对比结果\n",
    "将对比结果可视化，以便更直观地分析不同算法的性能。"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 可视化对比结果\n",
    "try:\n",
    "    # 加载对比结果\n",
    "    with open(f'{output_dir}/algorithm_comparison.json', 'r', encoding='utf-8') as f:\n",
    "        comparison_results = json.load(f)\n",
    "    \n",
    "    # 准备数据\n",
    "    algorithms = list(comparison_results.keys())\n",
    "    n_clusters = [result['n_clusters'] for result in comparison_results.values()]\n",
    "    n_noise = [result['n_noise'] for result in comparison_results.values()]\n",
    "    silhouette = [result['metrics'].get('silhouette_score', 0) for result in comparison_results.values()]\n",
    "    db_index = [result['metrics'].get('davies_bouldin_score', 999) for result in comparison_results.values()]\n",
    "    ch_index = [result['metrics'].get('calinski_harabasz_score', 0) for result in comparison_results.values()]\n",
    "    \n",
    "    # 创建DataFrame\n",
    "    df = pd.DataFrame({
    "        'Algorithm': algorithms,\n    "        'Clusters': n_clusters,\n    "        'Noise Points': n_noise,\n    "        'Silhouette Score': silhouette,\n    "        'DB Index': db_index,\n    "        'CH Index': ch_index\n    "    })\n",
    "    \n",
    "    print(\"\n算法性能对比:")\n",
    "    display(df)\n",
    "    \n",
    "    # 可视化\n",
    "    fig, axes = plt.subplots(2, 2, figsize=(15, 12))\n",
    "    \n",
    "    # 聚类数量\n",
    "    sns.barplot(x='Algorithm', y='Clusters', data=df, ax=axes[0, 0])\n",
    "    axes[0, 0].set_title('Number of Clusters')\n",
    "    axes[0, 0].set_ylabel('Clusters')\n",
    "    \n",
    "    # 噪声点数量\n",
    "    sns.barplot(x='Algorithm', y='Noise Points', data=df, ax=axes[0, 1])\n",
    "    axes[0, 1].set_title('Number of Noise Points')\n",
    "    axes[0, 1].set_ylabel('Noise Points')\n",
    "    \n",
    "    # 轮廓系数\n",
    "    sns.barplot(x='Algorithm', y='Silhouette Score', data=df, ax=axes[1, 0])\n",
    "    axes[1, 0].set_title('Silhouette Score')\n",
    "    axes[1, 0].set_ylabel('Score')\n",
    "    axes[1, 0].set_ylim(0, 1)\n",
    "    \n",
    "    # DB指数和CH指数\n",
    "    df_melt = df.melt(id_vars='Algorithm', value_vars=['DB Index', 'CH Index'],\n    "                    var_name='Metric', value_name='Value')\n",
    "    sns.barplot(x='Algorithm', y='Value', hue='Metric', data=df_melt, ax=axes[1, 1])\n",
    "    axes[1, 1].set_title('DB Index and CH Index')\n",
    "    axes[1, 1].set_ylabel('Value')\n",
    "    \n",
    "    plt.tight_layout()\n",
    "    plt.savefig(f'{report_dir}/algorithm_comparison.png', dpi=300, bbox_inches='tight')\n",
    "    plt.show()\n",
    "    \n",
    "    print(f"\n可视化结果已保存到: {report_dir}/algorithm_comparison.png")\n",
    "except Exception as e:\n",
    "    print(f"可视化失败: {e}")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. 选择最佳算法\n",
    "基于评估指标选择最佳算法。"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 选择最佳算法\n",
    "try:\n",
    "    # 加载对比结果\n",
    "    with open(f'{output_dir}/algorithm_comparison.json', 'r', encoding='utf-8') as f:\n",
    "        comparison_results = json.load(f)\n",
    "    \n",
    "    # 计算综合得分\n",
    "    scores = {}\n",
    "    for algo, result in comparison_results.items():\n",
    "        metrics = result['metrics']\n",
    "        if 'silhouette_score' in metrics:\n",
    "            # 综合得分：轮廓系数(权重0.6) + CH指数(标准化后权重0.4)\n",
    "            silhouette = metrics['silhouette_score']\n",
    "            ch = metrics.get('calinski_harabasz_score', 0)\n",
    "            # 标准化CH指数\n",
    "            ch_scores = [r['metrics'].get('calinski_harabasz_score', 0) for r in comparison_results.values() if 'calinski_harabasz_score' in r['metrics']]\n",
    "            if ch_scores:\n",
    "                ch_normalized = (ch - min(ch_scores)) / (max(ch_scores) - min(ch_scores)) if max(ch_scores) > min(ch_scores) else 0\n",
    "            else:\n",
    "                ch_normalized = 0\n",
    "            scores[algo] = 0.6 * silhouette + 0.4 * ch_normalized\n",
    "    \n",
    "    if scores:\n",
    "        # 选择得分最高的算法\n",
    "        best_algo = max(scores.items(), key=lambda x: x[1])\n",
    "        print(\"\n" + "="*60)\n",
    "        print(\"最佳算法选择")\n",
    "        print(\"="*60)\n",
    "        print(f"最佳算法: {best_algo[0].upper()}")\n",
    "        print(f"综合得分: {best_algo[1]:.4f}")\n",
    "        \n",
    "        # 使用最佳算法进行聚类\n",
    "        engine.config['algorithm'] = best_algo[0]\n",
    "        labels = engine.fit(best_algo[0])\n",
    "        \n",
    "        # 保存最佳算法结果\n",
    "        best_result_path = f'{output_dir}/best_clustering_result.json'\n",
    "        engine.save_results(best_result_path)\n",
    "        \n",
    "        # 可视化最佳算法结果\n",
    "        viz_path = f'{report_dir}/best_clustering_visualization.png'\n",
    "        engine.visualize_clusters(save_path=viz_path)\n",
    "        \n",
    "        print(f"\n最佳算法聚类结果已保存到: {best_result_path}")\n",
    "        print(f"可视化结果已保存到: {viz_path}")\n",
    "    else:\n",
    "        print(\"无法计算综合得分，可能是因为评估指标不足")\n",
    "except Exception as e:\n",
    "    print(f"选择最佳算法失败: {e}")\n",
    "    import traceback\n",
    "    traceback.print_exc()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 5. 聚类结果分析\n",
    "分析最佳算法的聚类结果，了解每个聚类的特点。"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 分析聚类结果\n",
    "try:\n",
    "    # 加载最佳算法结果\n",
    "    best_result_path = f'{output_dir}/best_clustering_result.json'\n",
    "    with open(best_result_path, 'r', encoding='utf-8') as f:\n",
    "        best_result = json.load(f)\n",
    "    \n",
    "    print(\"\n" + "="*60)\n",
    "    print(\"聚类结果分析")\n",
    "    print(\"="*60)\n",
    "    print(f"使用算法: {best_result['algorithm'].upper()}")\n",
    "    print(f"聚类数量: {best_result['cluster_stats']['n_clusters']}")\n",
    "    print(f"噪声点数量: {best_result['cluster_stats']['n_noise']}")\n",
    "    \n",
    "    if best_result['cluster_stats']['cluster_sizes']:\n",
    "        print(\"\n聚类大小分布:")\n",
    "        for cluster_id, size in sorted(best_result['cluster_stats']['cluster_sizes'].items()):\n",
    "            print(f"  聚类 {cluster_id}: {size} 个样本")\n",
    "    \n",
    "    # 分析每个聚类的样本\n",
    "    print(\"\n各聚类样本分析:")\n",
    "    cluster_samples = {}\n",
    "    for sample in best_result['samples']:\n",
    "        cluster_id = sample['cluster_id']\n",
    "        if cluster_id not in cluster_samples:\n",
    "            cluster_samples[cluster_id] = []\n",
    "        cluster_samples[cluster_id].append(sample)\n",
    "    \n",
    "    for cluster_id, samples in sorted(cluster_samples.items()):\n",
    "        if cluster_id == -1:\n",
    "            print(f"\n噪声点 ({len(samples)} 个):")\n",
    "        else:\n",
    "            print(f"\n聚类 {cluster_id} ({len(samples)} 个):")\n",
    "        \n",
    "        # 显示前5个样本\n",
    "        for i, sample in enumerate(samples[:5]):\n",
    "            print(f"  {i+1}. {sample['coordinateName']} (v{sample['version']})")\n",
    "        if len(samples) > 5:\n",
    "            print(f"  ... 等{len(samples) - 5}个样本")\n",
    "    \n",
    "except Exception as e:\n",
    "    print(f"分析聚类结果失败: {e}")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 6. 总结与建议\n",
    "总结实验结果并给出建议。"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 总结与建议\n",
    "print(\"\n" + "="*60)\n",
    "print(\"实验总结")\n",
    "print(\"="*60)\n",
    "\n",
    "print(\"1. 算法性能总结:")\n",
    "print(\"   - DBSCAN: 适合发现任意形状的聚类，对噪声点敏感\")\n",
    "print(\"   - K-Means: 速度快，适合球形聚类\")\n",
    "print(\"   - 层次聚类: 可以形成层次结构，适合小数据集\")\n",
    "print(\"   - HDBSCAN: 层次密度聚类，自动确定聚类数量\")\n",
    "\n",
    "print(\"2. 选择建议:")\n",
    "print(\"   - 样本数量大: 优先选择DBSCAN或HDBSCAN\")\n",
    "print(\"   - 样本数量小: 可以选择K-Means或层次聚类\")\n",
    "print(\"   - 噪声点多: 优先选择DBSCAN或HDBSCAN\")\n",
    "print(\"   - 计算资源有限: 选择K-Means\")\n",
    "\n",
    "print(\"3. 后续优化方向:")\n",
    "print(\"   - 调整算法参数以获得更好的聚类效果\")\n",
    "print(\"   - 尝试特征降维以提高聚类效率\")\n",
    "print(\"   - 结合领域知识对聚类结果进行验证\")\n",
    "print(\"   - 建立SDK信誉库，将新SDK与已知聚类进行比较\")\n",
    "\n",
    "print(\"4. 运行建议:")\n",
    "print(\"   - 对于大规模数据，建议使用并行处理\")\n",
    "print(\"   - 定期更新聚类模型以适应新的SDK样本\")\n",
    "print(\"   - 结合其他分析方法（如频繁项挖掘）发现SDK的共同特征\")"
   ]
  }
